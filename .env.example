# Contract RAG API - Environment Variables
# =========================================
# Copy this file to .env and fill in your values

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# File Upload Settings
MAX_FILES=5
MAX_FILE_SIZE=52428800  # 50MB in bytes
UPLOAD_DIR=/tmp/contract_rag/uploads
CHUNKS_DIR=/tmp/contract_rag/chunks

# Document Processing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Embedding Settings
# Options: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (multilingual)
#          sentence-transformers/all-MiniLM-L6-v2 (English only, faster)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# Vector Store Settings
VECTOR_STORE_TYPE=faiss
SIMILARITY_THRESHOLD=0.3

# RAG Settings
DEFAULT_TOP_K=5
MAX_CONTEXT_LENGTH=4000
MAX_QUESTION_LENGTH=1000

# LLM Settings
# Provider options: openai, anthropic, local (mock)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.1

# OpenAI API Key (required if LLM_PROVIDER=openai)
LLM_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# CORS Settings (comma-separated origins)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
